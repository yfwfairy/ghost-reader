{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./.typecheck/tsconfig.node.tsbuildinfo",
    "outDir": "./.typecheck/node",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["electron.vite.config.ts", "src/main", "src/preload", "src/shared"]
}
